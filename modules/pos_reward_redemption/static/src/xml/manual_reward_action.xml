<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="pos_reward_redemption.NavbarInherit"
       t-inherit="point_of_sale.Navbar"
       t-inherit-mode="extension">

        <xpath expr="//button[hasclass('orders-button')]" position="after">
            <button class="reward-button btn btn-lg btn-light lh-lg"
                    t-on-click="manualRedeem"
                    title="Đổi Điểm">
                <t t-if="!ui.isSmall">
                    <i class="fa fa-gift text-warning me-1"/>
                    <span>Reward</span>
                </t>
                <i t-else="" class="fa fa-fw fa-gift text-warning"
                   t-att-class="{'fa-lg': !ui.isSmall}"/>
            </button>
        </xpath>

    </t>
</templates>
