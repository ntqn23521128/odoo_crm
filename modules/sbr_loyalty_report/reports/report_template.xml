<odoo>
	<template id="report_loyalty_template">
		<t t-call="web.html_container">
			<t t-foreach="docs" t-as="o">
				<t t-call="web.external_layout">
					<div class="page">
						<h2 class="text-center mt-4">
							<span t-field="o.name"/>
						</h2>
						<p>
							<strong>Điểm tối thiểu lọc:</strong>
							<span t-field="o.min_points"/>
						</p>

						<table class="table table-sm table-bordered mt-3">
							<thead>
								<tr style="background-color: #f2f2f2;">
									<th>STT</th>
									<th>Tên Khách Hàng</th>
									<th>Số điện thoại</th>
									<th class="text-end">Điểm tích lũy</th>
									<th class="text-center">Hạng</th>
								</tr>
							</thead>
							<tbody>
								<t t-set="idx" t-value="1"/>
								<tr t-foreach="o.partner_ids" t-as="partner">
									<td>
										<span t-esc="idx"/>
									</td>
									<td>
										<span t-field="partner.name"/>
									</td>
									<td>
										<span t-field="partner.phone"/>
									</td>
									<td class="text-end">
										<span t-field="partner.star_points"/>
									</td>
									<td class="text-center">
										<span t-if="partner.loyalty_tier == 'gold'" class="badge rounded-pill text-bg-warning">Gold</span>
										<span t-if="partner.loyalty_tier == 'green'" class="badge rounded-pill text-bg-success">Green</span>
									</td>
									<t t-set="idx" t-value="idx + 1"/>
								</tr>
							</tbody>
						</table>

						<div class="row mt-4">
							<div class="col-12 text-end">
								<p>
									Ngày xuất báo cáo: <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y')"/>
								</p>
							</div>
						</div>
					</div>
				</t>
			</t>
		</t>
	</template>
</odoo>