<odoo>
    <record id="view_loyalty_report_form" model="ir.ui.view">
        <field name="name">starbucks.loyalty.report.form</field>
        <field name="model">starbucks.loyalty.report</field>
        <field name="arch" type="xml">
            <form string="Loyalty Report">
                <header>
                    <button name="action_generate_report" string="Lấy dữ liệu" type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="min_points"/>
                    </group>
                    <notebook>
                        <page string="Kết quả tìm kiếm">
                            <field name="partner_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="phone"/>
                                    <field name="star_points"/>
                                    <field name="loyalty_tier"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_loyalty_report_tree" model="ir.ui.view">
        <field name="name">starbucks.loyalty.report.list</field>
        <field name="model">starbucks.loyalty.report</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="action_loyalty_report" model="ir.actions.act_window">
        <field name="name">Báo cáo điểm khách hàng</field>
        <field name="res_model">starbucks.loyalty.report</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>