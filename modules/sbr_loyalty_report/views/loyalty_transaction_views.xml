<odoo>
    <record id="view_starbucks_point_history_report_tree" model="ir.ui.view">
        <field name="name">starbucks.point.history.report.tree</field>
        <field name="model">starbucks.point.history</field>
        <field name="arch" type="xml">
            <tree string="Loyalty Transactions" create="false" edit="false">
                <field name="date"/>
                <field name="partner_id"/>
                <field name="type"/>
                <field name="points"/>
                <field name="order_id"/>
                <field name="report_id" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="action_starbucks_point_history_report" model="ir.actions.act_window">
        <field name="name">Transaction History</field>
        <field name="res_model">starbucks.point.history</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_starbucks_point_history_report_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No transactions found
            </p>
        </field>
    </record>
</odoo>